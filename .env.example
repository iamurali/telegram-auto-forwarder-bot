# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Get API_ID and API_HASH from https://my.telegram.org
# Get SESSION_STRING by running: python generate_session.py

API_ID=
API_HASH=
SESSION_STRING=

# test_forward.py — source channel and recipient (not committed; .env is gitignored)
# Telegram Web URL #4396610825 -> API id -1004396610825 (prefix -100, drop leading -)
TEST_SOURCE_CHAT_ID=
TEST_RECIPIENT_ID=

# Optional
# TEST_ROUTE_NAME=test-channel
# TEST_HEADER_LABEL=Test Channel

# Optional: for local forward.py runs (single-line JSON)
# ROUTES_JSON=[{"name":"my-channel","source_chat_id":-1001234567890,"recipients":[111111111]}]
